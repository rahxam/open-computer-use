# Open Computer Use - Environment Variables
# Copy this file to .env and customize

# === LLM Provider (required) ===
# Works with any OpenAI-compatible API: OpenAI, OpenRouter, LiteLLM, etc.
OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# === Computer Use Server ===
# MCP API key for endpoint authorization (leave empty for development)
MCP_API_KEY=
# Docker image used for sandbox containers
DOCKER_IMAGE=open-computer-use:latest
# Timeouts
COMMAND_TIMEOUT=120
SUB_AGENT_TIMEOUT=3600
# Single-user mode:
#   not set  = lenient (default container + warning if no X-Chat-Id)
#   true     = always use one container, no chat ID needed
#   false    = strict multi-user, X-Chat-Id required
# SINGLE_USER_MODE=true

# === PostgreSQL ===
POSTGRES_PASSWORD=openwebui

# === Open WebUI ===
OPENWEBUI_VERSION=0.8.12
OPENWEBUI_PORT=3000
MCP_PORT=8081

# === Optional: Large tool result truncation ===
# Prevents context window exhaustion from large MCP tool outputs (Metabase, Playwright, etc.)
# Requires fix_large_tool_results patch enabled in openwebui/Dockerfile
# TOOL_RESULT_MAX_CHARS=50000
# TOOL_RESULT_PREVIEW_CHARS=2000

# === Optional: Vision API (for describe-image skill) ===
# VISION_API_KEY=
# VISION_API_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o

# === Optional: Claude Code sub-agent ===
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional model overrides for Claude Code (supports LiteLLM / Azure Foundry model IDs)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-4-6
# Set when your gateway/provider rejects Claude Code prompt caching fields
# DISABLE_PROMPT_CACHING=1
# Optional extra fallback for gateways that reject Anthropic beta fields
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# === Optional: GitLab integration ===
# GITLAB_HOST=gitlab.com
# GITLAB_TOKEN=
